# ─────────────────────────────────────────────────────────────
# Python .gitignore
# TEMPLATE NOTE: Add project-specific files below the sections
# ─────────────────────────────────────────────────────────────

# Environment & Secrets — NEVER commit these
.env
.env.local
.env.*.local
*.pem
*.key

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Testing & Coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# Database files (dev only — not for production)
*.db
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
